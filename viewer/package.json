{
  "name": "msp-podping-viewer",
  "version": "1.0.0",
  "private": true,
  "description": "Hive podping firehose viewer: collector + enricher + search/SSE API.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc && cp src/schema.sql dist/schema.sql",
